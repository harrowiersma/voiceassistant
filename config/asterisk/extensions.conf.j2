; Auto-generated extensions.conf — do not edit manually

[inbound]
; Incoming calls routed to AudioSocket for AI processing
; Accept ANY extension (DID numbers, 's', anything DIDWW sends)
exten => _X.,1,NoOp(Incoming call from ${CALLERID(num)} to ${EXTEN})
 same => n,Ringing()
 same => n,Wait(4)
 same => n,Answer()
 same => n,Set(UUID=${SHELL(cat /proc/sys/kernel/random/uuid | tr -d '\n')})
 same => n,AudioSocket(${UUID},127.0.0.1:9092)
 same => n,Hangup()

exten => s,1,NoOp(Incoming call from ${CALLERID(num)} to s)
 same => n,Ringing()
 same => n,Wait(4)
 same => n,Answer()
 same => n,Set(UUID=${SHELL(cat /proc/sys/kernel/random/uuid | tr -d '\n')})
 same => n,AudioSocket(${UUID},127.0.0.1:9092)
 same => n,Hangup()

exten => _+X.,1,NoOp(Incoming call from ${CALLERID(num)} to ${EXTEN})
 same => n,Ringing()
 same => n,Wait(4)
 same => n,Answer()
 same => n,Set(UUID=${SHELL(cat /proc/sys/kernel/random/uuid | tr -d '\n')})
 same => n,AudioSocket(${UUID},127.0.0.1:9092)
 same => n,Hangup()

[outbound]
; Outbound dialling — uses outbound trunk if configured, falls back to inbound
{% if sip_outbound_server %}
exten => _X.,1,NoOp(Outbound call to ${EXTEN} via outbound trunk)
 same => n,Dial(PJSIP/${EXTEN}@outbound-endpoint)
 same => n,Hangup()
{% else %}
exten => _X.,1,NoOp(Outbound call to ${EXTEN} via inbound trunk)
 same => n,Dial(PJSIP/${EXTEN}@inbound-endpoint)
 same => n,Hangup()
{% endif %}

[internal]
; Internal extensions can dial each other and outbound
exten => _X.,1,NoOp(Internal call to ${EXTEN})
 same => n,Dial(PJSIP/${EXTEN})
 same => n,Hangup()

[forward]
; Per-person forwarding: try internal extension first (10s), then external number (30s)
; FORWARD_EXT and FORWARD_TO are set by the engine before redirecting here
exten => s,1,NoOp(Forwarding call to ext=${FORWARD_EXT} external=${FORWARD_TO})
 same => n,GotoIf($["${FORWARD_EXT}" = ""]?external)
 same => n,Dial(PJSIP/${FORWARD_EXT},10)
 same => n(external),GotoIf($["${FORWARD_TO}" = ""]?ai-message,s,1)
 same => n,Dial(PJSIP/${FORWARD_TO}@{% if sip_outbound_server %}outbound-endpoint{% else %}inbound-endpoint{% endif %},30,g)
 same => n,Goto(ai-message,s,1)

[ai-message]
exten => s,1,NoOp(No answer - AI taking message)
 same => n,Set(UUID=${SHELL(cat /proc/sys/kernel/random/uuid | tr -d '\n')})
 same => n,AudioSocket(${UUID},127.0.0.1:9092)
 same => n,Hangup()
