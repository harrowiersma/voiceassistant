; Auto-generated rtp.conf — RTP and NAT traversal

[general]
rtpstart=10000
rtpend=20000
{% if sip_stun_server %}
stunaddr={{ sip_stun_server }}
icesupport=yes
{% endif %}
; Strict RTP helps with NAT — only accept RTP from the address that sends us packets
strictrtp=yes
; Probation period (number of packets before locking to a source)
probation=4
