[outbound-endpoint]
type=endpoint
transport=transport-udp
context=outbound
disallow=all
allow=ulaw
allow=alaw
outbound_auth=outbound-auth
aors=outbound-aor
from_user={{ sip_outbound_username }}
from_domain={{ sip_outbound_server }}
{% endif %}
{% if sip_extension_1_name %}

; ── Internal Extension: {{ sip_extension_1_name }} ───────────────────────
[{{ sip_extension_1_name }}]
type=endpoint
transport=transport-udp
context=internal
