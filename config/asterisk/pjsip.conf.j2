allow=ulaw
allow=alaw
auth={{ sip_extension_1_name }}-auth
aors={{ sip_extension_1_name }}-aor

[{{ sip_extension_1_name }}-auth]
type=auth
auth_type=userpass
username={{ sip_extension_1_name }}
password={{ sip_extension_1_password }}

[{{ sip_extension_1_name }}-aor]
