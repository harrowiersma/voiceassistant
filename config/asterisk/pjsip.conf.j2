; Auto-generated pjsip.conf — do not edit manually

; ── Transport ──────────────────────────────────────────────
[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0

; ── Inbound Trunk ──────────────────────────────────────────
[inbound-reg]
type=registration
transport=transport-udp
outbound_auth=inbound-auth
server_uri=sip:{{ sip_inbound_server }}:{{ sip_inbound_port }}
client_uri=sip:{{ sip_inbound_username }}@{{ sip_inbound_server }}:{{ sip_inbound_port }}

[inbound-auth]
type=auth
auth_type=userpass
username={{ sip_inbound_username }}
password={{ sip_inbound_password }}

[inbound-aor]
type=aor
contact=sip:{{ sip_inbound_server }}:{{ sip_inbound_port }}

[inbound-endpoint]
type=endpoint
transport=transport-udp
context=inbound
disallow=all
allow=ulaw
allow=alaw
outbound_auth=inbound-auth
aors=inbound-aor
from_user={{ sip_inbound_username }}
from_domain={{ sip_inbound_server }}

; Identify inbound calls from DIDWW by IP — accept ALL calls from their servers
[inbound-identify]
type=identify
endpoint=inbound-endpoint
match=46.19.209.0/24
match=46.19.210.0/24
match=46.19.211.0/24
match=185.location.0.0/16
match={{ sip_inbound_server }}
{% if sip_outbound_server %}

; ── Outbound Trunk ─────────────────────────────────────────
[outbound-reg]
type=registration
transport=transport-udp
outbound_auth=outbound-auth
server_uri=sip:{{ sip_outbound_server }}:{{ sip_outbound_port }}
client_uri=sip:{{ sip_outbound_username }}@{{ sip_outbound_server }}:{{ sip_outbound_port }}

[outbound-auth]
