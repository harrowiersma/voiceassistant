# Voice Secretary Configuration
# Copy this to .env and fill in your actual values
# This file is loaded on first boot to seed the database

# ===== SIP Trunk (DIDWW) =====
SIP_INBOUND_SERVER=sip.didww.com
SIP_INBOUND_PORT=5060
SIP_INBOUND_USERNAME=
SIP_INBOUND_PASSWORD=
SIP_FORWARD_NUMBER=

# Outbound trunk (optional - leave empty to use inbound for outbound)
SIP_OUTBOUND_SERVER=
SIP_OUTBOUND_PORT=5060
SIP_OUTBOUND_USERNAME=
SIP_OUTBOUND_PASSWORD=
SIP_STUN_SERVER=

# Internal extensions (optional)
SIP_EXTENSION_1_NAME=
SIP_EXTENSION_1_PASSWORD=
SIP_EXTENSION_2_NAME=
SIP_EXTENSION_2_PASSWORD=
SIP_EXTENSION_3_NAME=
SIP_EXTENSION_3_PASSWORD=

# ===== Persona =====
PERSONA_COMPANY_NAME=
PERSONA_GREETING=Hello, you've reached {company}. How may I help you?
PERSONA_PERSONALITY=You are a professional, friendly, and concise virtual secretary.
PERSONA_UNAVAILABLE_MESSAGE=I'm sorry, they're not available right now. May I take a message?

# ===== Microsoft Graph (Teams Presence + Calendar) =====
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=

# ===== Google Calendar (per-persona, optional) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== SMTP Email =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
NOTIFY_ON=message_only

# ===== Secret Code Word (caller says this to bypass availability and connect immediately) =====
SECRET_CODE_WORD=

# ===== Availability =====
AVAILABILITY_MANUAL_OVERRIDE=auto
AVAILABILITY_BUSINESS_HOURS_START=09:00
AVAILABILITY_BUSINESS_HOURS_END=17:00
AVAILABILITY_ACTION_AVAILABLE=forward
AVAILABILITY_ACTION_BUSY=take_message
AVAILABILITY_ACTION_DND=take_message
AVAILABILITY_ACTION_AWAY=take_message

# ===== AI Settings =====
AI_STT_MODEL=vosk-small
AI_LLM_MODEL=llama3.2:1b
AI_TTS_VOICE=en-us-amy-medium
AI_RESPONSE_TIMEOUT=10
AI_MAX_CALL_DURATION=300
